# Database
DATABASE_URL=postgresql://user:pass@host:5432/db

# Auth
JWT_SECRET=your-32-char-min-secret-here

# File Storage (Cloudflare R2)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=dw-church-files
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Email (Resend)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=DW Church <noreply@truelight.app>

# Super Admin
SUPER_ADMIN_EMAILS=admin@example.com

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx

# Monitoring (optional)
SENTRY_DSN=

# Server
PORT=3000
NODE_ENV=production
CORS_ORIGINS=https://admin.truelight.app,https://truelight.app

# Cache invalidation (used by Next.js web app, not the server)
# REVALIDATE_SECRET=your-secret-here
